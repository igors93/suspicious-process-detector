# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Python build files
build/
dist/
*.egg-info/
.eggs/

# Test and coverage files
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Type checking / linting cache
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Generated reports
reports/*.json
reports/*.csv
reports/*.html
!reports/.gitkeep

# Logs
logs/*.log
logs/*.txt
!logs/.gitkeep

# Local config files
config/settings.json

# Temporary files
tmp/
temp/
*.tmp